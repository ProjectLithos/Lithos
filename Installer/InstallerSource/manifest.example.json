{
  "schemaVersion": 1,
  "sdkVersion": "0.17.25",
  "releaseStatus": "source-ready",
  "libc": {
    "implementation": "Newlib",
    "version": "4.6.0.20260123",
    "sourceUrl": "https://sourceware.org/pub/newlib/newlib-4.6.0.20260123.tar.gz",
    "sha256": "6ff27e3bf022666f43f7802255be680eeff722ac181b1725d21e2e8318604ee3",
    "targets": [
      "x86_64-elf"
    ],
    "configurations": [
      "Debug",
      "Release"
    ]
  },
  "packages": [
    {
      "name": "OESDK LibC Source",
      "path": "ReleaseAssets/OESDK-LibC-0.0.16-Source.zip"
    },
    {
      "name": "OESDK LibC Integration",
      "path": "ReleaseAssets/OESDK-LibC-0.0.16.zip"
    },
    {
      "name": "OESDK LibC Symbols",
      "path": "ReleaseAssets/OESDK-LibC-Symbols-0.0.16.zip",
      "generatedAfterBuild": true
    }
  ],
  "packageRevision": "0.17.25",
  "packageType": "complete-script-only",
  "contains": [
    "full-source",
    "libc",
    "visual-studio-setup-script",
    "updater"
  ],
  "containsCustomExecutable": false,
  "installedLayout": {
    "include": "Include",
    "source": "Source",
    "architecture": "Architecture",
    "tools": "Tools",
    "visualStudio": "VisualStudio",
    "fullInstallerSource": "InstallerSource"
  },
  "libcBuild": {
    "mode": "separate",
    "script": "Tools/Build-LibC.ps1",
    "excludedFromKernelBuild": true
  },
  "debugging": {
    "visualStudioLocalWindowsDebuggerRemoved": true,
    "guestDebugger": "MSYS2 GDB multiarch",
    "qemuGdbServer": "127.0.0.1:1234",
    "script": "Tools/Debug-Kernel.ps1",
    "symbols": "Build/<Configuration>/kernel.elf",
    "visualStudioF5Command": "cmd.exe /D /C call \"<ProjectDir>\\Debug-Kernel.cmd\"",
    "elfExecutedAsWin32": false,
    "fallbackDebugger": "Visual Studio LLDB",
    "diagnosticLog": "Build/Debug/oesdk-debug.log",
    "launcherLog": "Build/Debug/oesdk-launcher.log",
    "debuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb-multiarch.exe",
    "lldbFallbackRemoved": true,
    "interactiveConsole": true,
    "interactiveConsoleTitle": "OESDK Kernel Debugger - GDB",
    "gdbSessionFile": "Build/Debug/Start-Gdb-Session.cmd"
  },
  "templatesRemoved": [
    "*Oryn*"
  ],
  "visualStudioTemplates": {
    "launchersCopiedIntoNewProjects": true,
    "repairTool": "Tools/Repair-Project-DebugLaunchers.ps1"
  },
  "documentation": {
    "gdbCommandReference": "Docs/GDB-Command-Reference.md",
    "bootContext": "Docs/Boot-Context.md",
    "panicAndAssertions": "Docs/Panic-and-Assertions.md",
    "cpuPrimitives": "Docs/CPU-Primitives.md",
    "statusContract": "Docs/Status-and-Errors.md",
    "gdtAndTss": "Docs/GDT-and-TSS.md",
    "idtAndExceptions": "Docs/IDT-and-Exceptions.md",
    "apiReference": "Docs/API/README.md",
    "apiDocumentationVerification": "Tests/VerifyApiDocumentation.py",
    "memoryMapNormalization": "Docs/Memory-Map-Normalisation.md",
    "physicalPageAllocator": "Docs/Bitmap-Page-Frame-Allocator.md",
    "virtualMemory": "Docs/Virtual-Memory.md"
  },
  "visualStudioSdkVersion": "0.17.25",
  "exceptionsAndInterrupts": {
    "architecture": "x86_64",
    "idtVectors": 256,
    "exceptionVectors": 32,
    "dedicatedIst": [
      "double-fault",
      "nmi",
      "machine-check"
    ],
    "pageFaultDecode": true,
    "registerDump": true,
    "handlerRegistration": true,
    "firstHandlers": [
      "divide-error",
      "invalid-opcode",
      "general-protection-fault",
      "page-fault",
      "double-fault",
      "machine-check"
    ],
    "interruptFrameIncludes": [
      "general-purpose-registers",
      "vector",
      "error-code",
      "rip",
      "cs",
      "rflags",
      "rsp",
      "ss"
    ]
  },
  "gdtAndTss": {
    "architecture": "x86_64",
    "ownedGdt": true,
    "selectors": {
      "null": "0x00",
      "kernelCode": "0x08",
      "kernelData": "0x10",
      "userData": "0x18",
      "userCode": "0x20",
      "tss": "0x28"
    },
    "tssBytes": 104,
    "istEntries": 7,
    "istStackBytes": 16384,
    "dedicatedIst": [
      "double-fault",
      "nmi",
      "machine-check"
    ]
  },
  "memoryMapNormalization": {
    "architectureIndependentTypes": 8,
    "maximumRegions": 256,
    "rangeModel": "half-open",
    "overflowValidation": true,
    "overlapDetection": true,
    "multiboot1Conversion": true,
    "sorting": true,
    "adjacentRegionCoalescing": true
  },
  "templateSafety": {
    "integerFormattingExamples": true
  },
  "physicalMemory": {
    "pageSize": 4096,
    "pageShift": 12,
    "allocator": "bitmap",
    "permanentReservations": [
      "page-zero",
      "kernel-image",
      "bootstrap-stack",
      "bootstrap-page-tables",
      "multiboot-structures",
      "memory-map-storage",
      "framebuffer",
      "allocator-bitmaps"
    ]
  },
  "virtualMemory": {
    "architecture": "x86_64",
    "pageSize": 4096,
    "addressBits": 48,
    "retainsBootstrapIdentityMap": true,
    "supports": [
      "map",
      "unmap",
      "translate",
      "2MiB-split",
      "nx"
    ]
  }
}
