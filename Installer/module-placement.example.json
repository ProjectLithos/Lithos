{
  "architecture": "Microkernel",
  "modules": [
    {
      "module": "NetworkStack",
      "mode": "User",
      "requiredCapabilities": [
        "Pci",
        "Interrupt",
        "Dma",
        "Timer"
      ]
    },
    {
      "module": "Filesystem",
      "mode": "User",
      "requiredCapabilities": [
        "BlockDevice",
        "Timer"
      ]
    },
    {
      "module": "DisplayServer",
      "mode": "Automatic",
      "requiredCapabilities": [
        "Framebuffer",
        "Input",
        "Timer"
      ]
    }
  ]
}
