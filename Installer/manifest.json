    "targets": [
      "x86_64-elf"
    ],
    "configurations": [
      "Debug",
      "Release"
    ]
  },
  "packages": [
    {
      "name": "OESDK LibC Source",
      "path": "ReleaseAssets/OESDK-LibC-0.0.16-Source.zip"
    },
    {
      "name": "OESDK LibC Integration",
      "path": "ReleaseAssets/OESDK-LibC-0.0.16.zip"
    },
    {
      "name": "OESDK LibC Symbols",
      "path": "ReleaseAssets/OESDK-LibC-Symbols-0.0.16.zip",
      "generatedAfterBuild": true
    }
  ],
  "packageRevision": "0.0.16.2",
  "packageType": "complete-script-only",
  "contains": [
    "full-source",
    "libc",
    "visual-studio-setup-script",
    "updater"
  ],
  "containsCustomExecutable": false,
  "installedLayout": {
    "include": "Include",
    "source": "Source",
    "architecture": "Architecture",
    "tools": "Tools",
    "visualStudio": "VisualStudio",
    "fullInstallerSource": "InstallerSource"
  },
  "libcBuild": {
    "mode": "separate",
    "script": "Tools/Build-LibC.ps1",
    "excludedFromKernelBuild": true
  },
  "debugging": {
    "visualStudioLocalWindowsDebuggerRemoved": true,
    "guestDebugger": "MSYS2 GDB multiarch",
    "qemuGdbServer": "127.0.0.1:1234",
    "script": "Tools/Debug-Kernel.ps1",
    "symbols": "Build/<Configuration>/kernel.elf",
    "visualStudioF5Command": "cmd.exe /D /C call \"<ProjectDir>\\Debug-Kernel.cmd\"",
    "elfExecutedAsWin32": false,
    "fallbackDebugger": "Visual Studio LLDB",
    "diagnosticLog": "Build/Debug/oesdk-debug.log",
    "launcherLog": "Build/Debug/oesdk-launcher.log",
    "debuggerPath": "C:\\msys64\\ucrt64\\bin\\gdb-multiarch.exe",
    "lldbFallbackRemoved": true,
    "interactiveConsole": true,
    "interactiveConsoleTitle": "OESDK Kernel Debugger - GDB",
    "gdbSessionFile": "Build/Debug/Start-Gdb-Session.cmd"
  },
  "templatesRemoved": [
    "*Oryn*"
  ],
  "visualStudioTemplates": {
    "launchersCopiedIntoNewProjects": true,
    "repairTool": "Tools/Repair-Project-DebugLaunchers.ps1"
  },
  "documentation": {
    "gdbCommandReference": "Docs/GDB-Command-Reference.md",
    "bootContext": "Docs/Boot-Context.md",
    "panicAndAssertions": "Docs/Panic-and-Assertions.md",
    "cpuPrimitives": "Docs/CPU-Primitives.md"
  }
